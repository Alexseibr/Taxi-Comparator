# Конфиг calib-receiver. Перезагрузить:  systemctl restart rwbtaxi-calib
PORT=<SET_IN_PRODUCTION>
HOST=<SET_IN_PRODUCTION>
CALIB_DIR=<SET_IN_PRODUCTION>
CALIB_RATE_LIMIT=<SET_IN_PRODUCTION>
# Чтобы включить токен — раскомментируй и задай. На фронте задай VITE_CALIB_TOKEN то же значение.
# CALIB_TOKEN=
VITE_TOMTOM_KEY=<SET_IN_PRODUCTION>
GOOGLE_MAPS_KEY=<SET_IN_PRODUCTION>
GOOGLE_API_KEY=<SET_IN_PRODUCTION>
WB_ADMIN_LOGIN=<SET_IN_PRODUCTION>
WB_ADMIN_PASSWORD=<SET_IN_PRODUCTION>
WB_DIR=<SET_IN_PRODUCTION>
# Anti-throttle для Gemini free-tier (2.0-* убраны, они дают limit:0):
VISION_MODELS=<SET_IN_PRODUCTION>
SCREENS_PROCESS_CONCURRENCY=<SET_IN_PRODUCTION>
SCREENS_PROCESS_MAX=<SET_IN_PRODUCTION>
WB_VIEWER_LOGIN=<SET_IN_PRODUCTION>
WB_VIEWER_PASSWORD=<SET_IN_PRODUCTION>

# Путь к JSONL-логу отработанных рекомендованных маршрутов.
# По умолчанию код пишет в /var/www/rwbtaxi/data/, но эта папка вне
# ReadWritePaths в rwbtaxi-screens.service (ProtectSystem=strict),
# поэтому сервис не может туда писать (EROFS). Кладём файл в
# подкаталог recommendations/, который уже разрешён в ReadWritePaths.
COMPLETED_LOG_PATH=<SET_IN_PRODUCTION>
